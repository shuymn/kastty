{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>shuymn/github-actions#main"],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update FONTTOOLS_VERSION in update-nerd-font.sh",
      "managerFilePatterns": ["scripts/update-nerd-font.sh"],
      "matchStrings": ["FONTTOOLS_VERSION=\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "fonttools",
      "datasourceTemplate": "pypi"
    },
    {
      "customType": "regex",
      "description": "Update BROTLI_VERSION in update-nerd-font.sh",
      "managerFilePatterns": ["scripts/update-nerd-font.sh"],
      "matchStrings": ["BROTLI_VERSION=\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "brotli",
      "datasourceTemplate": "pypi"
    },
    {
      "customType": "regex",
      "description": "Update NERD_FONTS_VERSION in update-nerd-font.sh",
      "managerFilePatterns": ["scripts/update-nerd-font.sh"],
      "matchStrings": ["NERD_FONTS_VERSION=\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "ryanoasis/nerd-fonts",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.*)$"
    }
  ]
}
